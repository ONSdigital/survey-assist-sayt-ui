FLASK_SECRET_KEY=replace-with-a-long-random-secret
SERVICE_NAME=Survey Assist SAYT UI
SAYT_API_URL=https://your-gateway-host/v1/survey-assist/sic-lookup
SA_EMAIL=survey-assist-sayt-ui@your-project.iam.gserviceaccount.com
AUTH_MODE=local
LOCAL_USERS_FILE=users.json
SESSION_COOKIE_SECURE=false
# Optional override. The bundled example_survey.json definition is used by default.
# SURVEY_DEFINITION_FILE=/app/config/survey.json

# When running in a container locally LOCAL_USERS_FILE=/app/users.json

# For Cloud Run / GCS auth file mode:
# AUTH_MODE=gcs
# GCP_AUTH_BUCKET_NAME=your-auth-bucket
# GCP_AUTH_BLOB_NAME=users.json
# SESSION_COOKIE_SECURE=true
